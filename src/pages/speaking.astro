---
import SiteLayout from "@/layouts/SiteLayout.astro";
import PageHeader from "@/components/primitives/PageHeader.astro";
import Section from "@/components/primitives/Section.astro";
import Eyebrow from "@/components/primitives/Eyebrow.astro";
import CtaPrimary from "@/components/primitives/CtaPrimary.astro";
import Rule from "@/components/primitives/Rule.astro";
import { PAGE_TITLES, PAGE_DESCRIPTIONS, STAGES } from "@/lib/constants";

const talks = [
  {
    title: "The AI-native organization",
    body: "What changes when a company is designed around AI from the start: team size, cost structure, and how fast it learns. The case study is my own fund — a venture firm whose research, meeting prep, and relationship memory run on AI agents I direct myself. I show the system as it works today — including what's still manual, and what broke on the way to making it work.",
    bestFor: "Conferences, executive audiences, innovation teams",
  },
  {
    title: "AI-native startups",
    body: "Software is getting cheap to build, and that moves the moat: away from \"can you ship it\" and toward what you control — workflows, distribution, operational data, trust in regulated processes. This talk maps what durable startups look like in that world, grounded in ENYA's investment thesis, with a version focused on Latin America, where constraint-heavy markets make the shift sharper.",
    bestFor: "Founder audiences, accelerators, universities",
  },
  {
    title: "AI inside the corporation",
    body: "Corporations already have what AI needs most — data, distribution, and real workflows. What they usually lack is a way to prove value fast. This session updates the corporate-innovation playbook for the agent era: which processes to hand to AI first, where human approval must stay, and how a small internal team can show results in weeks instead of quarters.",
    bestFor: "Corporate events, leadership offsites, executive education",
  },
];

const formats = [
  {
    name: "Keynote",
    body: "20 to 60 minutes, adapted to your audience and program. Live demonstration included whenever the room allows it.",
  },
  {
    name: "Workshop",
    body: "Half-day, hands-on. Teams leave with a map of their own workflows and a first agent-assisted process to try the following week.",
  },
  {
    name: "Courses & training",
    body: "Multi-session programs for founders or executives. Teaching is where I started: I taught mathematics at Universidad Complutense de Madrid during my PhD, and later built 10xU, Rokk3r's education platform, which reached more than 25,000 students.",
  },
];
---

<SiteLayout
  title={PAGE_TITLES.speaking}
  description={PAGE_DESCRIPTIONS.speaking}
  path="/speaking"
>
  <PageHeader
    eyebrow="Speaking"
    title="AI-native, explained by someone who runs on it."
    supporting="Keynotes, workshops, and courses — in English, Spanish, or Italian. Every talk draws on the same source: twenty years of building companies, and a fund that operates on AI agents today."
  />

  <!-- Talks -->
  <Section compact>
    <div data-reveal>
      <Eyebrow>Three talks, one thesis</Eyebrow>
    </div>
    <div class="mt-10 grid gap-12 lg:gap-14">
      {
        talks.map((t, i) => (
          <article class="grid gap-6 md:grid-cols-[minmax(0,1fr)_minmax(0,2fr)] md:gap-12" data-reveal style={`--reveal-i: ${i % 2};`}>
            <div>
              <Rule strong class="mb-5" />
              <h2 class="text-d3" style="color: var(--color-ink);">
                {t.title}
              </h2>
            </div>
            <div>
              <p class="text-lg leading-relaxed" style="color: var(--color-muted-strong);">
                {t.body}
              </p>
              <p class="text-eyebrow mt-5" style="color: var(--color-muted);">
                Best for · {t.bestFor}
              </p>
            </div>
          </article>
        ))
      }
    </div>
    <p class="mt-12 max-w-3xl text-lg" style="color: var(--color-muted-strong);" data-reveal>
      Same talk, native delivery, in English, Spanish, or Italian. Every topic
      adapts from a 20-minute keynote to a half-day workshop.
    </p>
  </Section>

  <!-- Photos -->
  <Section compact>
    <div class="grid gap-4 md:grid-cols-3">
      <figure class="ldl-shot md:col-span-2" data-reveal>
        <img src="/images/workshop.jpg" alt="Lorenzo de Leo giving a workshop to a full room" loading="lazy" />
      </figure>
      <figure class="ldl-shot" data-reveal style="--reveal-i: 1;">
        <img src="/images/d3.jpg" alt="Lorenzo de Leo on a panel at D3 Bahamas" loading="lazy" />
      </figure>
    </div>
  </Section>

  <!-- Formats -->
  <Section
    class="border-y"
    style="border-color: var(--color-rule); background: color-mix(in srgb, var(--color-paper-deep) 55%, var(--color-paper));"
  >
    <div data-reveal>
      <Eyebrow>Formats</Eyebrow>
    </div>
    <div class="mt-10 grid gap-10 md:grid-cols-3 md:gap-8">
      {
        formats.map((f, i) => (
          <article data-reveal style={`--reveal-i: ${i};`}>
            <h2 class="text-title" style="color: var(--color-ink);">
              {f.name}
            </h2>
            <p class="mt-3 leading-relaxed" style="color: var(--color-muted-strong);">
              {f.body}
            </p>
          </article>
        ))
      }
    </div>
  </Section>

  <!-- Proof -->
  <Section compact>
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <div data-reveal>
          <Eyebrow>Stages</Eyebrow>
        </div>
        <ul class="mt-8 flex flex-wrap gap-x-7 gap-y-3" data-reveal style="--reveal-i: 1;">
          {
            STAGES.map((s) => (
              <li class="text-lg font-medium" style="color: var(--color-muted-strong);">
                {s}
              </li>
            ))
          }
        </ul>
      </div>
      <div data-reveal style="--reveal-i: 2;">
        <Eyebrow>Heard from the audience</Eyebrow>
        <blockquote class="mt-8">
          <p class="text-title" style="color: var(--color-ink);">
            “Lorenzo's approach to complex concepts is transformative, turning
            bewildering ideas into empowering knowledge for all audiences.”
          </p>
          <footer class="mt-4 text-base" style="color: var(--color-muted);">
            Andrea Arnau — investor, Shark Tank celebrity
          </footer>
        </blockquote>
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section style="background: var(--color-ink); color: var(--color-paper);">
    <div class="max-w-4xl">
      <div data-reveal>
        <Eyebrow inverted>Booking</Eyebrow>
      </div>
      <h2 class="text-d2 mt-6" style="color: var(--color-paper);" data-reveal-lines>
        Tell me about your event and what you want the room to leave with.
      </h2>
      <div class="mt-10" data-reveal style="--reveal-i: 2;">
        <CtaPrimary href="/contact" inverted>Get in touch</CtaPrimary>
      </div>
    </div>
  </Section>
</SiteLayout>

<style>
  .ldl-shot {
    margin: 0;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid var(--color-rule-strong);
  }
  .ldl-shot img {
    width: 100%;
    height: 100%;
    min-height: 260px;
    object-fit: cover;
  }
</style>
